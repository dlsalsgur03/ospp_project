<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Back button removed for fragment tab -->

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="리더보드"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_tab_container"
        android:padding="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp">

        <TextView
            android:id="@+id/tabPersonal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="개인"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#191A1D"
            android:background="@drawable/bg_tab_selected" />

        <TextView
            android:id="@+id/tabDepartment"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="학과"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#191A1D" />

        <TextView
            android:id="@+id/tabCollege"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="단과"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#333333" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDateRange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="05.11  -  05.17"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#8C8C8C"
        app:layout_constraintTop_toBottomOf="@id/tabContainer"
        app:layout_constraintStart_toStartOf="@id/tabContainer"
        android:layout_marginTop="18dp" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollLeaderboard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvDateRange"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/tabContainer"
        app:layout_constraintEnd_toEndOf="@id/tabContainer"
        android:layout_marginTop="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP 3 영역 -->
            <LinearLayout
                android:id="@+id/layoutTopThree"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:orientation="horizontal"
                android:gravity="bottom">

                <!-- 2등 -->
                <LinearLayout
                    android:id="@+id/cardRank2"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rank_2"
                    android:padding="10dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvTop2Rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2위"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#4F5660" />

                    <TextView
                        android:id="@+id/tvTop2Main"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="사용자 2"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#2F2F2F"
                        android:layout_marginTop="8dp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvTop2Sub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="전자정보대학 · 컴퓨터공학과"
                        android:textSize="10sp"
                        android:textColor="#5F5F5F"
                        android:layout_marginTop="5dp"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvTop2Score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="900 EXP"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#2F2F2F"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="match_parent" />

                <!-- 1등 -->
                <LinearLayout
                    android:id="@+id/cardRank1"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_weight="1.25"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rank_1"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvTop1Rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1위"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#5A4100" />

                    <TextView
                        android:id="@+id/tvTop1Main"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="사용자 1"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#2F2F2F"
                        android:layout_marginTop="10dp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvTop1Sub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="전자정보대학 · 컴퓨터공학과"
                        android:textSize="11sp"
                        android:textColor="#5F5F5F"
                        android:layout_marginTop="6dp"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvTop1Score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1000 EXP"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#2F2F2F"
                        android:layout_marginTop="10dp" />
                </LinearLayout>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="match_parent" />

                <!-- 3등 -->
                <LinearLayout
                    android:id="@+id/cardRank3"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rank_3"
                    android:padding="10dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvTop3Rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3위"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#6A3C19" />

                    <TextView
                        android:id="@+id/tvTop3Main"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="사용자 3"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#2F2F2F"
                        android:layout_marginTop="8dp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvTop3Sub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="전자정보대학 · 소프트웨어학부"
                        android:textSize="10sp"
                        android:textColor="#5F5F5F"
                        android:layout_marginTop="5dp"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvTop3Score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="850 EXP"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#2F2F2F"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- 4위부터 리스트 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingTop="16dp"
                android:paddingBottom="24dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>