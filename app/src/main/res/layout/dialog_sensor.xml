<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background"
    android:padding="20dp">

    <!-- 1. X 닫기 버튼 (최상단) -->
    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 2. 캐릭터 영역 (높이를 줄여서 위로 올림) -->
    <FrameLayout
        android:id="@+id/layout_character_container"
        android:layout_width="300dp"
        android:layout_height="220dp"
        app:layout_constraintTop_toBottomOf="@id/btn_close"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/img_sensor"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            app:civ_border_width="5dp"
            app:civ_border_color="#E91E8C" />
    </FrameLayout>

    <!-- 3. 로딩 상태 텍스트 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="센서 데이터를 분석 중입니다..."
        android:textColor="#333333"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layout_character_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 4. 로딩 프로그레스바 -->
    <ProgressBar
        android:id="@+id/progress_collect"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        android:indeterminateTint="#E91E8C"
        app:layout_constraintTop_toBottomOf="@id/tv_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 5. 획득 버튼 (사진과의 간격을 위해 마진 30dp 부여) -->
    <Button
        android:id="@+id/btn_collect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="30dp"
        android:text="획득"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E91E8C"
        style="@style/Widget.MaterialComponents.Button"
        app:layout_constraintTop_toBottomOf="@id/progress_collect"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 6. 환경 정보 보기 버튼 -->
    <Button
        android:id="@+id/btn_toggle_sensor_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="▼ 환경 정보 보기"
        android:visibility="gone"
        android:backgroundTint="#E91E8C"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/btn_collect"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 7. 측정 데이터 레이아웃 (최하단) -->
    <LinearLayout
        android:id="@+id/layout_sensor_data"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btn_toggle_sensor_data">

        <TextView
            android:id="@+id/tv_temp_hum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="온도: --°C / 습도: --%"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/tv_air_eco2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="공기질: -- / eCO2: --ppm"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_gravity="center" />
        <TextView
            android:id="@+id/tv_rssi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RSSI : -- dBm"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_gravity="center"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>